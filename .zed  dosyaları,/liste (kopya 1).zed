    }
    don sonuc;
}

// Listeyi yazdir
fonk liste_yaz(lst) {
    degisken cikti = "[";
    degisken i = 0;
    iken i < uzunluk(lst) {
        cikti = cikti + lst[i];
        eger i < uzunluk(lst) - 1 {
            cikti = cikti + ", ";
        }
        i = i + 1;
    }
    cikti = cikti + "]";
    yaz cikti;
}

// Bubble sort (kucukten buyuge)
fonk sirala(lst) {
    degisken n = uzunluk(lst);
    degisken sonuc = [];
    // Kopyala
    degisken k = 0;
    iken k < n {
        ekle(sonuc, lst[k]);
        k = k + 1;
    }
    // Bubble sort
    degisken i = 0;
    iken i < n {
        degisken j = 0;
        iken j < n - i - 1 {
            eger sonuc[j] > sonuc[j + 1] {
                degisken tmp = sonuc[j];
                sonuc[j] = sonuc[j + 1];
                sonuc[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    don sonuc;
}

// Buyukten kucuge sirala
fonk sirala_ters(lst) {
    don tersine(sirala(lst));
}

// Aralik olustur (range)
fonk aralik(baslangic, bitis) {
    degisken sonuc = [];
    degisken i = baslangic;
    iken i < bitis {
        ekle(sonuc, i);
        i = i + 1;
    }
    don sonuc;
}

// Adimli aralik
fonk aralik_adim(baslangic, bitis, adim) {
    degisken sonuc = [];
    degisken i = baslangic;
    iken i < bitis {
        ekle(sonuc, i);
        i = i + adim;
    }
    don sonuc;
